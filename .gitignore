# Logs and cache files
*.log
*.cache
*.tmp

# Per-machine Hyprland overrides (each host maintains its own copy)
hypr/.config/hypr/local.conf

# Generated at runtime by switch-theme.sh / btop itself
btop/.config/btop/themes/active.theme
btop/.config/btop/btop.conf

# Generated by scripts/generate-dynamic-theme.sh (machine-local)
themes/dynamic.sh
btop/.config/btop/themes/dynamic.theme
ghostty/.config/ghostty/themes/dynamic
