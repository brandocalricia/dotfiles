# Secrets must NEVER be committed. The restic backup keeps all secrets in
# /etc/restic/ (root-owned, 0600, outside this repo), so they cannot be
# committed regardless — these patterns are a defensive backstop.
*.pass
*.env
*secret*
*.key

# Logs and cache files
*.log
*.cache
*.tmp

# Per-machine overrides. The real content is TRACKED per host as
# local.<hostname>.conf / local.<hostname>.jsonc so every machine's config lives
# in the repo and is visible to the others. The bare names below are host-selected
# SYMLINKS (created by scripts/apply-host-local.sh) pointing at this host's file —
# they differ per machine, so they stay ignored. Seed a new host from *.example.
hypr/.config/hypr/local.conf
waybar/.config/waybar/local.jsonc

# Generated at runtime by switch-theme.sh / btop itself
btop/.config/btop/themes/active.theme
btop/.config/btop/btop.conf

# Generated theme outputs — live files written by switch-theme.sh on every
# switch. Tracked as <file>.base seeds; install.sh copies base -> live on first
# run. switch-theme.sh writes ONLY these (and the *.theme above), so the tree
# stays clean in any theme/dynamic mode. See SETUP-NOTES "theme output model".
waybar/.config/waybar/style.css
foot/.config/foot/foot.ini
hypr/.config/hypr/hyprlock.conf
hypr/.config/hypr/colors.conf
mako/.config/mako/config
fuzzel/.config/fuzzel/fuzzel.ini
fastfetch/.config/fastfetch/config.jsonc
ghostty/.config/ghostty/themes/active

# Generated by scripts/generate-dynamic-theme.sh (machine-local)
themes/dynamic.sh
btop/.config/btop/themes/dynamic.theme
