# Machine-specific overrides. Copy this file to local.conf and edit for your host.
# local.conf is gitignored — each machine maintains its own copy.
#
# Monitors (per-machine). Example desktop layout:
#   monitor = DP-1, 1920x1080@165, 0x0, 1
#   monitor = HDMI-A-1, 2560x1440@143.91, 1920x0, 1
#
# Workspace <-> monitor split (per-machine, since it references monitor names).
# Bind 1-5 to your main monitor and 6-10 to the secondary; mark the first of
# each group default:true. Single-monitor hosts can instead just declare
#   workspace = 1, persistent:true   (… through 10) with no monitor: clause.
#   workspace = 1, monitor:HDMI-A-1, default:true, persistent:true
#   workspace = 2, monitor:HDMI-A-1, persistent:true
#   … (3-5 on main) …
#   workspace = 6, monitor:DP-1, default:true, persistent:true
#   workspace = 7, monitor:DP-1, persistent:true
#   … (8-10 on secondary) …

# Wallpaper (required — main config sources this file).
# swww gives animated transitions; set-wallpaper.sh seds the 'swww img' path.
# (Older hosts may still use a single swaybg line — that also works.)
exec-once = swww-daemon
exec-once = sleep 1 && swww img ~/Pictures/wallpapers/YOUR_WALLPAPER.png --transition-type none
